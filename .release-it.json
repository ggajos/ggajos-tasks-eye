{
  "$schema": "https://unpkg.com/release-it@20/schema/release-it.json",
  "git": {
    "requireBranch": "master",
    "commitMessage": "Release ${version}",
    "tagName": "${version}",
    "tagAnnotation": "${version}"
  },
  "npm": {
    "publish": false,
    "skipChecks": true
  },
  "github": {
    "release": false
  },
  "hooks": {
    "before:bump": [
      "node scripts/obsidian-release.mjs check",
      "npm test",
      "npm run build",
      "node scripts/obsidian-release.mjs check-release-visual",
      "npm run docs"
    ],
    "after:bump": "node scripts/obsidian-release.mjs sync ${version}",
    "after:git:release": "node scripts/obsidian-release.mjs github-release ${version}"
  }
}
